# Generated by Ansible — do not edit manually
# {{ ansible_managed }}

# Ollama — points to API server (same host on API server, remote IP on UI server)
{% if server_role == 'api' %}
OLLAMA_BASE_URL=http://localhost:{{ ollama_port }}
{% else %}
OLLAMA_BASE_URL=http://{{ hostvars['api']['ansible_host'] }}:{{ ollama_port }}
{% endif %}
OLLAMA_MODEL={{ ollama_llm_model }}
EMBEDDING_MODEL={{ ollama_embed_model }}

# ChromaDB — always local (each server has its own store; UI reads API via HTTP)
CHROMA_PERSIST_DIR={{ app_dir }}/data/chroma_db
CHROMA_COLLECTION_NAME=documents

# File uploads
UPLOAD_DIR={{ app_dir }}/data/uploads

# S3
S3_BUCKET={{ s3_bucket }}
S3_REGION={{ s3_region }}
S3_UPLOADS_PREFIX={{ s3_uploads_prefix }}
S3_CHROMA_PREFIX={{ s3_chroma_prefix }}

# API
API_HOST=0.0.0.0
API_PORT={{ api_port }}

# MCP
MCP_HOST=0.0.0.0
MCP_PORT={{ mcp_port }}

# Chunking
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
