[Unit]
Description=RAG Chatbot — FastAPI
# Start after Ollama is up (Ollama must be ready before API takes queries)
After=network.target ollama.service
Requires=ollama.service

[Service]
Type=simple
User={{ app_user }}
WorkingDirectory={{ app_dir }}
EnvironmentFile={{ app_dir }}/.env
ExecStart={{ app_venv }}/bin/uvicorn src.api.main:app \
    --host 0.0.0.0 \
    --port {{ api_port }} \
    --workers 2 \
    --log-level info
Restart=always
RestartSec=5
StandardOutput=append:{{ app_dir }}/logs/api.log
StandardError=append:{{ app_dir }}/logs/api.log

[Install]
WantedBy=multi-user.target
