upstream rag_ui {
    server 127.0.0.1:{{ ui_port }};
}

server {
    listen 80;
    server_name _;   # replace with your domain if you have one

    # Streamlit needs these headers for WebSocket support
    location / {
        proxy_pass         http://rag_ui;
        proxy_http_version 1.1;
        proxy_set_header   Upgrade           $http_upgrade;
        proxy_set_header   Connection        "upgrade";
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_read_timeout 86400s;   # keep Streamlit WebSocket alive
        proxy_send_timeout 86400s;
    }

    # Streamlit static assets
    location /_stcore/ {
        proxy_pass         http://rag_ui/_stcore/;
        proxy_http_version 1.1;
        proxy_set_header   Upgrade     $http_upgrade;
        proxy_set_header   Connection  "upgrade";
    }
}
